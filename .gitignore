# Virtual environment - excludes all packages installed locally
venv/

# Environment variables - contains sensitive API keys, never commit this
.env

# Python bytecode cache - auto-generated by Python interpreter
__pycache__/
*.pyc
*.pyo
*.pyd

# SQLite database files - local development databases
*.sqlite3

# Distribution and build artifacts
dist/
build/
*.egg-info/

# OS-specific files
.DS_Store
Thumbs.db

# IDE and editor directories
.vscode/
.idea/

# pytest cache
.pytest_cache/

# mypy type checking cache
.mypy_cache/
