# Virtual environment - excludes all packages installed locally
venv/

# Environment variables - contains sensitive API keys, never commit this
.env

# Python bytecode cache - auto-generated by Python interpreter
__pycache__/
*.pyc
*.pyo
*.pyd

# SQLite database files - local development databases
*.sqlite3

# Distribution and build artifacts
dist/
build/
*.egg-info/

# OS-specific files
.DS_Store
Thumbs.db

# IDE and editor directories
.vscode/
.idea/

# pytest cache
.pytest_cache/

# mypy type checking cache
.mypy_cache/

# Evaluation results - may contain sensitive business intelligence scores
eval/*.json

# ML model checkpoints (too large for Git)
ml_models/best_checkpoint/

# SQLite test database (auto-generated by pytest)
test.db

# Node.js dependencies
node_modules/

# Next.js build output
.next/

# SEC data downloads
sec_data/