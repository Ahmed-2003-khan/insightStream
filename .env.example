# OpenAI API key — get from platform.openai.com
OPENAI_API_KEY=

# Pinecone API key — get from app.pinecone.io
PINECONE_API_KEY=

# Pinecone index name — create index named 'insightstream'
PINECONE_INDEX_NAME=

# Secret key for API authentication — any strong random string
API_SECRET_KEY=

# Tavily API key — get from tavily.com
TAVILY_API_KEY=

# LangSmith API key — get from smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_PROJECT=insightstream-production

# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/insightstream

# Redis connection string
REDIS_URL=redis://localhost:6379
